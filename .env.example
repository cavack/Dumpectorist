APP_ENV=development
APP_NAME=dumpectorist
API_HOST=0.0.0.0
API_PORT=8787
API_BIND=127.0.0.1:8787

POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me
POSTGRES_BIND=127.0.0.1:5432
REDIS_BIND=127.0.0.1:6379
DATABASE_URL=postgresql+asyncpg://app:change_me@postgres:5432/app
REDIS_URL=redis://redis:6379/0

TELEGRAM_BOT_TOKEN=change_me
TELEGRAM_ADMIN_IDS=
ENABLE_LIVE_ACTIONS=false
MAX_LEVERAGE=5

WORKER_TICK_SECONDS=1
WORKER_SOURCE_TIMEOUT_SECONDS=8
WORKER_EXECUTION_INTERVAL_SECONDS=5
WORKER_BENCHMARK_INTERVAL_SECONDS=10
WORKER_OHLCV_INTERVAL_SECONDS=300
WORKER_DISCOVERY_INTERVAL_SECONDS=300
WORKER_CLEANUP_INTERVAL_SECONDS=3600
WORKER_RETENTION_DAYS=30
WORKER_FAILURE_ALERT_THRESHOLD=3

WORKER_ENABLE_LBANK=true
WORKER_ENABLE_BENCHMARKS=true
WORKER_ENABLE_OHLCV=true
WORKER_ENABLE_DISCOVERY=true
WORKER_LBANK_SYMBOL=BTCUSDT
WORKER_MEXC_SYMBOL=BTC_USDT
WORKER_GATE_SYMBOL=BTC_USDT
WORKER_BYBIT_SYMBOL=BTCUSDT
WORKER_BINANCE_SYMBOL=BTCUSDT
WORKER_OHLCV_SYMBOL=BTCUSDT
WORKER_OHLCV_LIMIT=200
